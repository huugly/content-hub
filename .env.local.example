# ─── Supabase ───────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — NEVER expose this to the browser. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Auth ────────────────────────────────────────────────────────────────────────
# The ONLY email allowed to log in. All others are silently rejected.
OWNER_EMAIL=your@email.com

# ─── APIs ────────────────────────────────────────────────────────────────────────
# YouTube Data API v3 — used for channel validation and metadata
# Get it from: https://console.cloud.google.com → Enable "YouTube Data API v3"
YOUTUBE_API_KEY=your-youtube-api-key-here

# Anthropic API — used for generating content ideas via Claude Haiku
# Get it from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Security ────────────────────────────────────────────────────────────────────
# Random secret used to authenticate cron job requests from GitHub Actions
# Generate with: openssl rand -hex 32
CRON_SECRET=generate-a-random-string-here

# ─── RSSHub ──────────────────────────────────────────────────────────────────────
# Used to fetch X (Twitter) posts as RSS feeds
# Default: use the public RSSHub instance (rate-limited, may be unreliable)
# Recommended: self-host RSSHub → https://docs.rsshub.app/deploy/
RSSHUB_BASE_URL=https://rsshub.app

# ─── App URL (used by GitHub Actions) ───────────────────────────────────────────
# Set this to your deployed Vercel URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
